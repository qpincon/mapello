# Required: at least 32 characters. Generate with: npx auth secret
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# The base URL of your app
BETTER_AUTH_URL=http://localhost:5173

# Optional: Google OAuth credentials
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SMTP) for password reset emails
# Defaults work with Mailpit on localhost:1025 (local dev mail catcher)
# Run: docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
# Then view emails at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CartoSVG <noreply@localhost>
