# Required: at least 32 characters. Generate with: npx auth secret
BETTER_AUTH_SECRET=your-secret-here-min-32-chars

# The base URL of your app
BETTER_AUTH_URL=http://localhost:5173

# Optional: Google OAuth credentials
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend API key for password reset emails
# Get this from https://resend.com/api-keys
RESEND_API_KEY=

# Optional: Facebook Sign In
# Create an app at developers.facebook.com, enable "Facebook Login" product
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Paddle billing
# Get these from https://vendors.paddle.com/ (sandbox: https://sandbox-vendors.paddle.com/)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Paddle client-side token (safe to expose, used by Paddle.js in the browser)
PUBLIC_PADDLE_CLIENT_TOKEN=

# Set to "sandbox" for testing, "production" for live
PUBLIC_PADDLE_ENV=sandbox

# Price IDs for your subscription products
PUBLIC_PADDLE_PRICE_MONTHLY=
PUBLIC_PADDLE_PRICE_YEARLY=
