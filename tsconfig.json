{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "resolveJsonModule": true,
    "allowJs": true,
    "isolatedModules": true,
    "checkJs": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules/*",
    "./dist/**/*",
    "src/assets/layers/**/*",
    "src/examples/**/*",
    "src/svg/exportScripts/**/*"
  ]
}
